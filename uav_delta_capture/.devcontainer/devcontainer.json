{
    "name": "ROS 2 Humble Drone Dev",
    "dockerComposeFile": "../../../../docker-compose.yml",
    "service": "ros2_humble",
    "workspaceFolder": "/workspace",
    "remoteUser": "root",
    "postCreateCommand": ". /opt/ros/humble/setup.sh && colcon build",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-iot.vscode-ros",
                "ms-python.python",
                "ms-vscode.cpptools"
            ]
        }
    }
}